<div class="container mt-4">
  <% if notice.present? %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <i class="bi bi-check-circle-fill"></i> <%= notice %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% end %>

  <div class="d-flex justify-content-between align-items-center pb-3">
    <h1 class="text-center fw-bold display-5 mx-auto">
      <i class="bi bi-box-seam"></i> Products
    </h1>
    <%= link_to 'New Product', new_product_path, class: "btn btn-primary btn-lg" %>
  </div>

  <div class="table-responsive">
    <table class="table table-hover table-bordered align-middle">
      <thead class="table-primary text-center">
        <tr>
          <th>Image</th>
          <th>Details</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @products.each do |product| %>
          <tr>
            <td class="text-center">
              <%= image_tag(product.image_url, class: 'img-thumbnail rounded', style: "width: 100px; height: auto;") %>
            </td>
            <td>
              <h5 class="fw-bold text-primary"><%= product.title %></h5>
              <p class="text-muted small"><%= truncate(strip_tags(product.description), length: 80) %></p>
              <span class="badge bg-success">Price: $<%= product.price %></span>
            </td>
            <td class="text-center">
              <div class="btn-group" role="group">
                <%= link_to product, class: "btn btn-outline-primary btn-sm" do %>
                  <i class="bi bi-eye"></i> Show
                <% end %>
                <%= link_to edit_product_path(product), class: "btn btn-outline-secondary btn-sm" do %>
                  <i class="bi bi-pencil"></i> Edit
                <% end %>
                <%= link_to product, method: :delete, 
                      data: { confirm: "Are you sure?" }, 
                      class: "btn btn-outline-danger btn-sm" do %>
                  <i class="bi bi-trash"></i> Delete
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
