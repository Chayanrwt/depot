<div class="container mt-4">
  <% if notice.present? %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <%= notice %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% end %>

  <div class="d-flex justify-content-between align-items-center pb-3">
    <h1 class="text-center fw-bold display-5 mx-auto">Products</h1>
    <%= link_to 'New Product', new_product_path, class: "btn btn-primary" %>
  </div>

  <div class="table-responsive">
    <table class="table table-striped table-bordered">
      <thead class="table-dark">
        <tr>
          <th>Image</th>
          <th>Details</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @products.each do |product| %>
          <tr>
            <td class="text-center">
              <%= image_tag(product.image_url, class: 'img-fluid rounded', style: "width: 100px;") %>
            </td>
            <td>
              <h5 class="fw-bold"><%= product.title %></h5>
              <p class="text-muted"><%= truncate(strip_tags(product.description), length: 80) %></p>
            </td>
            <td>
              <div class="btn-group">
                <%= link_to 'Show', product, class: "btn btn-outline-primary btn-sm" %>
                <%= link_to 'Edit', edit_product_path(product), class: "btn btn-outline-secondary btn-sm" %>
                <%= link_to 'Delete', product, method: :delete, 
                      data: { confirm: "Are you sure?" }, 
                      class: "btn btn-outline-danger btn-sm" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
