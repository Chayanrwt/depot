<%= form_with(model: product, class: "needs-validation", novalidate: true) do |form| %>
  <% if product.errors.any? %>
    <div class="alert alert-danger" role="alert">
      <h4 class="alert-heading">
        <i class="bi bi-exclamation-triangle-fill"></i> 
        <%= pluralize(product.errors.count, "error") %> prevented this product from being saved:
      </h4>
      <ul>
        <% product.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :title, class: "form-label fw-bold" %>
    <%= form.text_field :title, class: "form-control", required: true, placeholder: "Enter product title" %>
  </div>

  <div class="mb-3">
    <%= form.label :description, class: "form-label fw-bold" %>
    <%= form.text_area :description, class: "form-control", rows: 5, required: true, placeholder: "Enter product description" %>
  </div>

  <div class="mb-3">
    <%= form.label :image_url, class: "form-label fw-bold" %>
    <%= form.text_field :image_url, class: "form-control", required: true, placeholder: "Enter image URL" %>
  </div>

  <div class="mb-3">
    <%= form.label :price, class: "form-label fw-bold" %>
    <%= form.number_field :price, class: "form-control", step: "0.01", required: true, placeholder: "Enter product price" %>
  </div>

  <div class="d-grid gap-2">
    <%= form.submit "Save Product", class: "btn btn-primary btn-lg" %>
  </div>
<% end %>
