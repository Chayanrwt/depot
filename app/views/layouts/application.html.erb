<!DOCTYPE html>
<html lang="en">
<head>
  <title>Pragprog Books Online Store</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <!-- Bootstrap CSS -->
  <%= stylesheet_link_tag "https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" %>

  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
</head>

<body>
  <header class="bg-success text-white py-3">
    <div class="container d-flex align-items-center">
      <%= image_tag 'logo.svg', alt: 'The Pragmatic Bookshelf', class: "me-3" %>
      <h1 class="h4 mb-0"><%= @page_title %></h1>
    </div>
  </header>

  <div class="d-flex">
    <!-- Sidebar Navigation -->
    <nav class="bg-dark text-white p-4 vh-100" style="width: 250px;">
      <ul class="nav flex-column">
        <li class="nav-item">
          <a class="nav-link text-white" href="/">Home</a>
        </li>
        <li class="nav-item">
          <a class="nav-link text-white" href="/questions">Questions</a>
        </li>
        <li class="nav-item">
          <a class="nav-link text-white" href="/news">News</a>
        </li>
        <li class="nav-item">
          <a class="nav-link text-white" href="/contact">Contact</a>
        </li>
      </ul>
    </nav>

    <!-- Main Content -->
    <main class="container mt-4">
      <%= yield %>
    </main>
  </div>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
